@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sssom: <https://w3id.org/sssom/schema/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix xwkont-source-term: <https://w3id.org/xwkont/source-term#> .

<https://w3id.org/xwkont/id#mapping:continuous-discrete:001> a sssom:Mapping ;
    rdfs:comment "GFO directly reifies the split under `Individual`, which is exactly the concept this crosswalk is tracking."@en ;
    sssom:confidence 1e+00 ;
    sssom:mapping_justification "semapv:ManualMappingCuration" ;
    sssom:object_id xwkont-source-term:xwkont-core-ContinuousDiscrete_candidate ;
    sssom:predicate_id skos:exactMatch ;
    sssom:subject_id xwkont-source-term:GFO-Continuous_Discrete_Discrete_presential .

<https://w3id.org/xwkont/id#mapping:continuous-discrete:007> a sssom:Mapping ;
    rdfs:comment "Reified hit, but activity-specific and one-sided; not enough to establish the general axis."@en ;
    sssom:confidence 2e-01 ;
    sssom:mapping_justification "semapv:ManualMappingCuration" ;
    sssom:object_id xwkont-source-term:TUpper-atomic ;
    sssom:subject_id xwkont-source-term:xwkont-core-ContinuousDiscrete_candidate .

xwkont-source-term:GFO-Continuous_Discrete_Discrete_presential rdfs:label "Continuous / Discrete / Discrete_presential"@en ;
    dcterms:source "GFO" .

xwkont-source-term:TUpper-atomic rdfs:label "atomic"@en ;
    dcterms:source "TUpper" .

xwkont-source-term:xwkont-core-ContinuousDiscrete_candidate rdfs:label "ContinuousDiscrete (candidate)"@en ;
    dcterms:source "xwkont-core" .

