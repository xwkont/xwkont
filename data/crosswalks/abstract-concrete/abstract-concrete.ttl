    dcterms:source "xwkont-core" .

xwkont-source-term:SUMO-Abstract rdfs:label "Abstract"@en ;
    dcterms:source "SUMO" .

xwkont-source-term:DOLCE-Abstract rdfs:label "Abstract"@en ;
    dcterms:source "DOLCE" .

xwkont-source-term:GFO-Abstract rdfs:label "Abstract"@en ;
    dcterms:source "GFO" .

