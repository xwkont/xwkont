    dcterms:source "GFO" .

xwkont-source-term:GUM-SimpleThing rdfs:label "SimpleThing"@en ;
    dcterms:source "GUM" .

xwkont-source-term:SUMO-Abstract_Proposition rdfs:label "Abstract / Proposition"@en ;
    dcterms:source "SUMO" .

xwkont-source-term:TUpper-object rdfs:label "object"@en ;
    dcterms:source "TUpper" .

xwkont-source-term:UFO-non_physical_endurants rdfs:label "non-physical endurants"@en ;
    dcterms:source "UFO" .

xwkont-source-term:YAMATO-informational_object_representation rdfs:label "informational object / representation"@en ;
