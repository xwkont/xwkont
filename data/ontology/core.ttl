@prefix xwkont-core: <https://w3id.org/xwkont/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

xwkont-core: a skos:ConceptScheme ;
    dcterms:title "XwkOnt Core Ontology"@en ;
    dcterms:created "2026-07-01" ;
    dcterms:source "Core Ontology"@en ;
    dcterms:relation "docs/ontology/core-glossary.md"@en ;
    dcterms:relation "docs/ontology/core-axioms.md"@en ;
    skos:scopeNote "Initial draft vocabulary for organizing top-level foundational-ontology comparison; not a replacement foundational ontology."@en .

xwkont-core:Entity a rdfs:Class, skos:Concept ;
    rdfs:label "Entity"@en ;
    skos:prefLabel "Entity"@en ;
    skos:definition "The broad comparison root for something that exists, is treated as existing, or is modeled as a subject of description by XwkOnt or a source ontology."@en ;
    skos:editorialNote "Candidate comparison root; not a final claim that all source ontologies use the same top category."@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Continuant a rdfs:Class, skos:Concept ;
    rdfs:label "Continuant"@en ;
    rdfs:subClassOf xwkont-core:Entity ;
    skos:prefLabel "Continuant"@en ;
    skos:definition "An entity considered for comparison as persisting, enduring, or being present through time, such as an object, quality, or role."@en ;
    skos:editorialNote "Candidate concept; source ontologies differ on this label and boundary."@en ;
    dcterms:relation "docs/crosswalks/concepts/continuant-occurrent.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Occurrent a rdfs:Class, skos:Concept ;
    rdfs:label "Occurrent"@en ;
    rdfs:subClassOf xwkont-core:Entity ;
    skos:prefLabel "Occurrent"@en ;
    skos:definition "An entity considered for comparison as unfolding, occurring, happening, or extending through time, such as a process or event."@en ;
    skos:editorialNote "Candidate concept; source ontologies differ on this label and boundary."@en ;
    dcterms:relation "docs/crosswalks/concepts/continuant-occurrent.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Abstract a rdfs:Class, skos:Concept ;
    rdfs:label "Abstract"@en ;
    rdfs:subClassOf xwkont-core:Entity ;
    skos:prefLabel "Abstract"@en ;
    skos:definition "An entity considered for comparison as lacking spatiotemporal location or embodiment, such as a number, proposition, or universal, contrasted with Concrete."@en ;
    skos:editorialNote "Candidate concept, modeled as a class pair sibling to Continuant/Occurrent per maintainer-confirmed modeling recommendation; the boundary with Concrete is source-dependent."@en ;
    dcterms:relation "docs/crosswalks/concepts/abstract-concrete.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Concrete a rdfs:Class, skos:Concept ;
    rdfs:label "Concrete"@en ;
    rdfs:subClassOf xwkont-core:Entity ;
    skos:prefLabel "Concrete"@en ;
    skos:definition "An entity considered for comparison as having spatiotemporal location or embodiment, such as a physical object, quality, or event, contrasted with Abstract."@en ;
    skos:editorialNote "Candidate concept, modeled as a class pair sibling to Continuant/Occurrent per maintainer-confirmed modeling recommendation; the boundary with Abstract is source-dependent."@en ;
    dcterms:relation "docs/crosswalks/concepts/abstract-concrete.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Universal a rdfs:Class, skos:Concept ;
    rdfs:label "Universal"@en ;
    rdfs:subClassOf xwkont-core:Entity ;
    skos:prefLabel "Universal"@en ;
    skos:altLabel "Type"@en ;
    skos:definition "An entity considered for comparison as a type, kind, category, or universal that classifies or is instantiated by individuals, contrasted with a particular individual."@en ;
    skos:editorialNote "Candidate concept, modeled as a direct Entity subclass, paralleling GFO's own top-level Category/Individual split and the same sibling-of-Continuant/Occurrent modeling pattern used for Abstract/Concrete. SUMO's narrower framing (as an Abstract subtype) and UFO's internal rigidity typology are not yet formalized."@en ;
    dcterms:relation "docs/crosswalks/concepts/universal-type.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Time a rdfs:Class, skos:Concept ;
    rdfs:label "Time"@en ;
    rdfs:subClassOf xwkont-core:Entity ;
    skos:prefLabel "Time"@en ;
    skos:definition "An entity considered for comparison as a temporal region, instant, or interval used to locate other entities in time."@en ;
    skos:editorialNote "Candidate concept, modeled as a direct Entity subclass rather than under Continuant or Occurrent, since most source ontologies with a Time category treat it as independent of that split (BFO is the sole exception, classifying Time as occurrent)."@en ;
    dcterms:relation "docs/crosswalks/concepts/time.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Space a rdfs:Class, skos:Concept ;
    rdfs:label "Space"@en ;
    rdfs:subClassOf xwkont-core:Entity ;
    skos:prefLabel "Space"@en ;
    skos:definition "An entity considered for comparison as a spatial region, place, or extent used to locate other entities in space."@en ;
    skos:editorialNote "Candidate concept, modeled as a direct Entity subclass, consistent with Time's placement, though source ontologies diverge more on this classification than they do for Time (BFO: continuant; DOLCE/GFO/GUM: independent sibling category; SUMO: physical/concrete)."@en ;
    dcterms:relation "docs/crosswalks/concepts/space.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Change a rdfs:Class, skos:Concept ;
    rdfs:label "Change"@en ;
    rdfs:subClassOf xwkont-core:Entity ;
    skos:prefLabel "Change"@en ;
    skos:definition "An entity considered for comparison as an alteration, transition, or difference an entity undergoes, contrasted with the entity's own persisting or unfolding through time."@en ;
    skos:editorialNote "Candidate concept, modeled as a direct Entity subclass rather than under Continuant or Occurrent, since sources diverge on this classification: GFO's own Change class is owl:disjointWith its Process class, while SUMO's InternalChange is typically treated as a Process subtype."@en ;
    dcterms:relation "docs/crosswalks/concepts/change.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Continuous a rdfs:Class, skos:Concept ;
    rdfs:label "Continuous"@en ;
    rdfs:subClassOf xwkont-core:Entity ;
    skos:prefLabel "Continuous"@en ;
    skos:definition "An entity considered for comparison as gapless, densely ordered, or without discrete boundaries between its parts or values, contrasted with the gap-having Discrete."@en ;
    skos:editorialNote "Candidate concept, modeled as one of two sibling sub-concepts (with Discrete) as direct Entity subclasses per maintainer-confirmed modeling recommendation, reflecting GFO's own sibling-class split under its top-level Individual category."@en ;
    dcterms:relation "docs/crosswalks/concepts/continuous-discrete.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Discrete a rdfs:Class, skos:Concept ;
    rdfs:label "Discrete"@en ;
    rdfs:subClassOf xwkont-core:Entity ;
    skos:prefLabel "Discrete"@en ;
    skos:definition "An entity considered for comparison as separated into distinct, countable, gap-bounded units or values, contrasted with the gapless Continuous."@en ;
    skos:editorialNote "Candidate concept, modeled as one of two sibling sub-concepts (with Continuous) as direct Entity subclasses per maintainer-confirmed modeling recommendation, reflecting GFO's own sibling-class split under its top-level Individual category."@en ;
    dcterms:relation "docs/crosswalks/concepts/continuous-discrete.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:OntologicalLevelStratum a rdfs:Class, skos:Concept ;
    rdfs:label "Ontological Level / Stratum"@en ;
    rdfs:subClassOf xwkont-core:Entity ;
    skos:prefLabel "Ontological Level / Stratum"@en ;
    skos:altLabel "Ontological Layer"@en ;
    skos:definition "An entity considered for comparison as a level, stratum, or layer used to classify other entities by kind of reality, such as material, mental, or social strata."@en ;
    skos:editorialNote "Candidate concept, modeled as a direct Entity subclass and as a single umbrella class rather than split, since it is a meta-level classifier orthogonal to the Continuant/Occurrent split, paralleling Universal's direct-Entity-sibling treatment. Source: GFO's own Ontological_layer class (gfo-base.owl), which further splits into Stratum and Level branches not yet formalized here."@en ;
    dcterms:relation "docs/crosswalks/concepts/ontological-level-stratum.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:ListSequence a rdfs:Class, skos:Concept ;
    rdfs:label "List / Sequence"@en ;
    rdfs:subClassOf xwkont-core:Entity ;
    skos:prefLabel "List / Sequence"@en ;
    skos:definition "An entity considered for comparison as an ordered collection whose members have an intrinsic sequence or position, such as a list or ordered set."@en ;
    skos:editorialNote "Candidate concept, modeled as a direct Entity subclass rather than under Abstract or Continuant, since sources diverge on this classification: SUMO places List under its own Abstract, while GUM places OrderedObject under its own concrete DecomposableObject lineage."@en ;
    dcterms:relation "docs/crosswalks/concepts/list-sequence.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:MindConsciousBeingAgent a rdfs:Class, skos:Concept ;
    rdfs:label "Mind / Conscious Being / Agent"@en ;
    rdfs:subClassOf xwkont-core:Continuant ;
    skos:prefLabel "Mind / Conscious Being / Agent"@en ;
    skos:definition "A continuant considered for comparison as a mind, conscious being, or agent capable of cognition, intention, or autonomous action, contrasted with the more generic Object."@en ;
    skos:editorialNote "Candidate concept, modeled as a sibling of Object under Continuant rather than a subclass of Object, reflecting a convergent cross-source pattern (SUMO's AutonomousAgent, DOLCE's Agentive Physical Object, YAMATO's weak agent) that specializes an object-like layer without being folded into it."@en ;
    dcterms:relation "docs/crosswalks/concepts/mind-conscious-being-agent.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:NonPhysicalObject a rdfs:Class, skos:Concept ;
    rdfs:label "Non-physical Object"@en ;
    rdfs:subClassOf xwkont-core:Continuant ;
    skos:prefLabel "Non-physical Object"@en ;
    skos:definition "A continuant considered for comparison as an endurant that is neither a physical object nor an amount of matter, such as a mental or social object."@en ;
    skos:editorialNote "Candidate concept, modeled under Continuant as a single umbrella class only, not split into a separate Social Object branch, since DOLCE-Lite's own base module (the qualifying core-tier source) supports only the broader non-physical-object class; the Mental-Object/Social-Object leaf split lives only in DOLCE's DnS extension module, out of this placement's scope."@en ;
    dcterms:relation "docs/crosswalks/concepts/non-physical-social-object.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Disposition a rdfs:Class, skos:Concept ;
    rdfs:label "Disposition"@en ;
    rdfs:subClassOf xwkont-core:Continuant ;
    skos:prefLabel "Disposition"@en ;
    skos:altLabel "Capacity"@en ;
    skos:definition "A continuant considered for comparison as a tendency, capacity, or potential an entity has to behave or be realized in a certain way under certain conditions."@en ;
    skos:editorialNote "Candidate concept, modeled as a sibling of Role under Continuant, following BFO's own treatment of disposition as a specifically dependent continuant. BFO's own Function subtype of disposition is not split out as a separate class here, since that subsumption is not yet cross-source-confirmed."@en ;
    dcterms:relation "docs/crosswalks/concepts/disposition-capacity.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Modality a rdfs:Class, skos:Concept ;
    rdfs:label "Modality"@en ;
    rdfs:subClassOf xwkont-core:Quality ;
    skos:prefLabel "Modality"@en ;
    skos:definition "A quality considered for comparison as a way of qualifying necessity, possibility, or contingency, such as an alethic or deontic modal characteristic."@en ;
    skos:editorialNote "Candidate concept, modeled under Quality following GUM's own direct structural treatment (ModalQuality as rdfs:subClassOf SimpleQuality), consistent with SUMO's AlethicAttribute."@en ;
    dcterms:relation "docs/crosswalks/concepts/modality.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Object a rdfs:Class, skos:Concept ;
    rdfs:label "Object"@en ;
    rdfs:subClassOf xwkont-core:Continuant ;
    skos:prefLabel "Object"@en ;
    skos:definition "A continuant considered for comparison as an individual thing, body, system, or object-like entity."@en ;
    skos:editorialNote "Candidate concept; exact source-specific boundaries are deferred to concept crosswalk work."@en ;
    dcterms:relation "docs/crosswalks/concepts/object.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Aggregate a rdfs:Class, skos:Concept ;
    rdfs:label "Aggregate"@en ;
    rdfs:subClassOf xwkont-core:Continuant ;
    skos:prefLabel "Aggregate"@en ;
    skos:definition "A continuant considered for comparison as a plurality of member parts that together form a unit under a uniform membership criterion, such as a collective of trees, contrasted with the more permissive Sum."@en ;
    skos:editorialNote "Candidate concept, modeled as a sibling of Object under Continuant, and as one of two sibling sub-concepts (with Sum) per maintainer-confirmed modeling recommendation, reflecting an even source split on unity-criterion strictness."@en ;
    dcterms:relation "docs/crosswalks/concepts/mereology-parthood-aggregate.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Sum a rdfs:Class, skos:Concept ;
    rdfs:label "Sum"@en ;
    rdfs:subClassOf xwkont-core:Continuant ;
    skos:prefLabel "Sum"@en ;
    skos:definition "A continuant considered for comparison as a criterion-free mereological sum of two or more entities, with no unity requirement on its members, contrasted with the stricter Aggregate."@en ;
    skos:editorialNote "Candidate concept, modeled as a sibling of Object under Continuant, and as one of two sibling sub-concepts (with Aggregate) per maintainer-confirmed modeling recommendation, reflecting an even source split on unity-criterion strictness."@en ;
    dcterms:relation "docs/crosswalks/concepts/mereology-parthood-aggregate.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Quality a rdfs:Class, skos:Concept ;
    rdfs:label "Quality"@en ;
    rdfs:subClassOf xwkont-core:Continuant ;
    skos:prefLabel "Quality"@en ;
    skos:definition "A continuant considered for comparison as a characteristic, feature, or way an entity is, usually understood as requiring a bearer."@en ;
    skos:editorialNote "Candidate concept; dependence semantics are deferred."@en ;
    dcterms:relation "docs/crosswalks/concepts/quality.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Role a rdfs:Class, skos:Concept ;
    rdfs:label "Role"@en ;
    rdfs:subClassOf xwkont-core:Continuant ;
    skos:prefLabel "Role"@en ;
    skos:definition "A continuant considered for comparison as something an entity has because of context, use, participation, or social or organizational arrangement."@en ;
    skos:editorialNote "Candidate concept; role, function, disposition, and relator boundaries are deferred."@en ;
    dcterms:relation "docs/crosswalks/concepts/role.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Boundary a rdfs:Class, skos:Concept ;
    rdfs:label "Boundary"@en ;
    rdfs:subClassOf xwkont-core:Continuant ;
    skos:prefLabel "Boundary"@en ;
    skos:definition "A continuant considered for comparison as a lower-dimensional, fiat-demarcated part of its host entity, such as an edge or surface, contrasted with the not-part-of-host Site."@en ;
    skos:editorialNote "Candidate concept, modeled as one of two sibling sub-concepts (with Site) per maintainer-confirmed modeling recommendation, reflecting BFO's and DOLCE's independently-converging part-of-host/not-part-of-host split."@en ;
    dcterms:relation "docs/crosswalks/concepts/boundary-site.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Site a rdfs:Class, skos:Concept ;
    rdfs:label "Site"@en ;
    rdfs:subClassOf xwkont-core:Continuant ;
    skos:prefLabel "Site"@en ;
    skos:definition "A continuant considered for comparison as a dependent place or region whose location is determined by a host entity without being part of it, such as a hole or a shadow, contrasted with the part-of-host Boundary."@en ;
    skos:editorialNote "Candidate concept, modeled as one of two sibling sub-concepts (with Boundary) per maintainer-confirmed modeling recommendation, reflecting BFO's and DOLCE's independently-converging part-of-host/not-part-of-host split."@en ;
    dcterms:relation "docs/crosswalks/concepts/boundary-site.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Process a rdfs:Class, skos:Concept ;
    rdfs:label "Process"@en ;
    rdfs:subClassOf xwkont-core:Occurrent ;
    skos:prefLabel "Process"@en ;
    skos:definition "An occurrent considered for comparison as temporally extended activity, happening, or change."@en ;
    skos:editorialNote "Candidate concept; XwkOnt does not assume that Process and Event are equivalent."@en ;
    dcterms:relation "docs/crosswalks/concepts/process.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Event a rdfs:Class, skos:Concept ;
    rdfs:label "Event"@en ;
    rdfs:subClassOf xwkont-core:Occurrent ;
    skos:prefLabel "Event"@en ;
    skos:definition "An occurrent considered for comparison as a happening, occurrence, or temporally located unit."@en ;
    skos:editorialNote "Candidate concept; the distinction between Event and Process remains unsettled across source ontologies."@en ;
    dcterms:relation "docs/crosswalks/concepts/event.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Quantity a rdfs:Class, skos:Concept ;
    rdfs:label "Quantity"@en ;
    rdfs:subClassOf xwkont-core:Concrete ;
    skos:prefLabel "Quantity"@en ;
    skos:altLabel "Amount of Matter"@en ;
    skos:definition "A concrete entity considered for comparison as an amount, portion, or quantity of matter or stuff, such as a mass of gold or a collection whose members can vary without changing its identity."@en ;
    skos:editorialNote "Candidate concept; covers several related but distinct source-ontology senses (see docs/crosswalks/concepts/quantity-amount-of-matter.md) that this placement does not assume resolve to one class. Modeled under Concrete per the DOLCE/UFO/GFO majority; SUMO's Abstract-side treatment and YAMATO's quality-value-like sense diverge and are not yet formalized."@en ;
    dcterms:relation "docs/crosswalks/concepts/quantity-amount-of-matter.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Proposition a rdfs:Class, skos:Concept ;
    rdfs:label "Proposition"@en ;
    rdfs:subClassOf xwkont-core:Abstract ;
    skos:prefLabel "Proposition"@en ;
    skos:altLabel "Content"@en ;
    skos:definition "An abstract entity considered for comparison as a purely combinatorial, representation-independent content that can be borne by multiple concrete representations, such as strings, sounds, or icons expressing the same claim."@en ;
    skos:editorialNote "Candidate concept, modeled under Abstract, following all three confirmed sources' (DOLCE, SUMO, YAMATO) own treatment of Proposition/Content as an Abstract subtype."@en ;
    dcterms:relation "docs/crosswalks/concepts/proposition-content.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:Relation a rdfs:Class, skos:Concept ;
    rdfs:label "Relation"@en ;
    rdfs:subClassOf xwkont-core:Entity ;
    skos:prefLabel "Relation"@en ;
    skos:definition "An entity considered for comparison as a connection, association, or relationship type among entities."@en ;
    skos:editorialNote "Candidate concept; whether relations should be first-class entities is source-dependent and remains uncertain."@en ;
    dcterms:relation "docs/crosswalks/concepts/relation.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:InformationArtifact a rdfs:Class, skos:Concept ;
    rdfs:label "Information Artifact"@en ;
    rdfs:subClassOf xwkont-core:Entity ;
    skos:prefLabel "Information Artifact"@en ;
    skos:altLabel "information artifact"@en ;
    skos:definition "An entity that records or carries information for XwkOnt use, such as a specification, reference, mapping, diagram source, or validation note."@en ;
    skos:editorialNote "Candidate support concept; may later move to metadata or provenance infrastructure."@en ;
    dcterms:relation "docs/crosswalks/concepts/information-artifact.md"@en ;
    skos:inScheme xwkont-core: .

xwkont-core:hasPart a rdf:Property ;
    rdfs:label "has part"@en ;
    rdfs:domain xwkont-core:Entity ;
    rdfs:range xwkont-core:Entity ;
    skos:definition "Relates a whole entity to another entity included as its part."@en ;
    skos:editorialNote "Structural only; mereological axioms are deferred."@en .

xwkont-core:partOf a rdf:Property ;
    rdfs:label "part of"@en ;
    rdfs:domain xwkont-core:Entity ;
    rdfs:range xwkont-core:Entity ;
    skos:definition "Relates an entity to a larger entity that includes it as a part."@en ;
    skos:editorialNote "Inverse formalization with has part is deferred."@en .

xwkont-core:participatesIn a rdf:Property ;
    rdfs:label "participates in"@en ;
    rdfs:domain xwkont-core:Continuant ;
    rdfs:range xwkont-core:Occurrent ;
    skos:definition "Relates a continuant to an occurrent in which the continuant is involved."@en ;
    skos:editorialNote "Participation conditions are deferred."@en .

xwkont-core:hasParticipant a rdf:Property ;
    rdfs:label "has participant"@en ;
    rdfs:domain xwkont-core:Occurrent ;
    rdfs:range xwkont-core:Continuant ;
    skos:definition "Relates an occurrent to a continuant involved in it."@en ;
    skos:editorialNote "Inverse formalization with participates in is deferred."@en .

xwkont-core:hasQuality a rdf:Property ;
    rdfs:label "has quality"@en ;
    rdfs:domain xwkont-core:Entity ;
    rdfs:range xwkont-core:Quality ;
    skos:definition "Relates an entity to a quality that characterizes it."@en ;
    skos:editorialNote "Whether all entities can have qualities is deferred."@en .

xwkont-core:qualityOf a rdf:Property ;
    rdfs:label "quality of"@en ;
    rdfs:domain xwkont-core:Quality ;
    rdfs:range xwkont-core:Entity ;
    skos:definition "Relates a quality to the entity it characterizes or requires as bearer."@en ;
    skos:editorialNote "Dependence formalization is deferred."@en .

xwkont-core:bearsRole a rdf:Property ;
    rdfs:label "bears role"@en ;
    rdfs:domain xwkont-core:Entity ;
    rdfs:range xwkont-core:Role ;
    skos:definition "Relates an entity to a role that the entity has in a context."@en ;
    skos:editorialNote "Context and dependence conditions are not yet formalized."@en .

xwkont-core:roleOf a rdf:Property ;
    rdfs:label "role of"@en ;
    rdfs:domain xwkont-core:Role ;
    rdfs:range xwkont-core:Entity ;
    skos:definition "Relates a role to the entity that bears it."@en ;
    skos:editorialNote "Context and dependence axioms are deferred."@en .

xwkont-core:dependsOn a rdf:Property ;
    rdfs:label "depends on"@en ;
    rdfs:domain xwkont-core:Entity ;
    rdfs:range xwkont-core:Entity ;
    skos:definition "Relates one entity to another entity that it requires in some sense."@en ;
    skos:editorialNote "Existential, generic, specific, historical, and contextual dependence are not yet separated."@en .

xwkont-core:mapsTo a rdf:Property ;
    rdfs:label "maps to"@en ;
    skos:definition "Relates an XwkOnt concept or relationship to another concept or relationship as a candidate mapping."@en ;
    skos:editorialNote "Transitional documentation property retained for early traceability; no RDFS domain or range is asserted, and detailed mappings should prefer SKOS mapping properties or explicit crosswalk mapping records."@en .

xwkont-core:documentedBy a rdf:Property ;
    rdfs:label "documented by"@en ;
    rdfs:domain xwkont-core:Entity ;
    rdfs:range xwkont-core:InformationArtifact ;
    skos:definition "Relates a concept, relationship, or claim to an information artifact that documents it."@en ;
    skos:editorialNote "Exact provenance model is deferred to publication or governance work."@en .
